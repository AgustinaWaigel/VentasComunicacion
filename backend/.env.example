# PostgreSQL (Supabase)
# Usar el Transaction Pooler (puerto 6543) para la app
DATABASE_URL="postgresql://usuario:contraseña@host:6543/postgres"

# Usar el Session Pooler (puerto 5432) para migraciones (prisma db push)
DIRECT_URL="postgresql://usuario:contraseña@host:5432/postgres"

PORT=5000
NODE_ENV=development
